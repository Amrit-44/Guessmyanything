# ============================================================
# GUESS MY ANYTHING — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#
# --- OPTION A: Local development (SQLite file) ---
# Use this for local dev. The path is relative to prisma/schema.prisma.
# Prisma resolves `file:../db/custom.db` to <project-root>/db/custom.db.
DATABASE_URL=file:../db/custom.db

# --- OPTION B: Production / Vercel (Turso libSQL) ---
# 1. Create a free Turso DB: https://turso.tech
# 2. Run: turso db create guess-my-anything
# 3. Get the URL: turso db show guess-my-anything --url
# 4. Get a token: turso db tokens create guess-my-anything
# 5. Set these in Vercel (Settings → Environment Variables):
#    DATABASE_URL = libsql://guess-my-anything-<your-handle>.turso.io
#    DATABASE_AUTH_TOKEN = <token from step 4>
#
# DATABASE_URL=libsql://guess-my-anything-<your-handle>.turso.io
# DATABASE_AUTH_TOKEN=eyXXXXXXXXXXXXXXXXXXXXXXXX

# --- OPTIONAL: Google Analytics ---
# Set NEXT_PUBLIC_GA_ID to your Google Analytics measurement ID to enable tracking.
# Leave unset to disable (no impact on performance).
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
